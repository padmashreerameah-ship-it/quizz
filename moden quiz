<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Tamil Nadu Traditions Quiz</title>
<style>
    body {
        font-family: 'Poppins', sans-serif;
        background: linear-gradient(135deg, #ff9933, #ffffff, #138808);
        margin: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
    }

    .quiz-container {
        background: white;
        padding: 25px;
        border-radius: 15px;
        width: 400px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        text-align: center;
        animation: fadeIn 1s ease-in-out;
    }

    h2 {
        margin-bottom: 20px;
    }

    .option {
        display: block;
        background: #f0f0f0;
        margin: 10px 0;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.3s;
    }

    .option:hover {
        background: #ffcc80;
        transform: scale(1.05);
    }

    button {
        margin-top: 15px;
        padding: 10px 20px;
        border: none;
        background: #ff5722;
        color: white;
        border-radius: 8px;
        cursor: pointer;
        font-size: 16px;
    }

    button:hover {
        background: #e64a19;
    }

    #result {
        font-size: 20px;
        font-weight: bold;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
</head>

<body>

<div class="quiz-container">
    <h2 id="question">Question</h2>
    <div id="options"></div>
    <button onclick="nextQuestion()">Next</button>
    <p id="result"></p>
</div>

<script>
const quiz = [
    {
        question: "1. What is the traditional dance of Tamil Nadu?",
        options: ["Kathak", "Bharatanatyam", "Kuchipudi", "Odissi"],
        answer: "Bharatanatyam"
    },
    {
        question: "2. Which festival is famous in Tamil Nadu for harvest?",
        options: ["Diwali", "Pongal", "Holi", "Onam"],
        answer: "Pongal"
    },
    {
        question: "3. What is the traditional food served on banana leaf?",
        options: ["Biryani", "Sadhya", "Tamil Virundhu", "Thali"],
        answer: "Tamil Virundhu"
    },
    {
        question: "4. Which instrument is commonly used in Tamil folk music?",
        options: ["Tabla", "Nadaswaram", "Guitar", "Piano"],
        answer: "Nadaswaram"
    },
    {
        question: "5. What is the traditional attire for Tamil men?",
        options: ["Kurta", "Lungi", "Veshti", "Dhoti"],
        answer: "Veshti"
    },
    {
        question: "6. Which temple is famous in Madurai?",
        options: ["Tirupati", "Meenakshi Temple", "Golden Temple", "Lotus Temple"],
        answer: "Meenakshi Temple"
    },
    {
        question: "7. What art is drawn at house entrances in Tamil Nadu?",
        options: ["Rangoli", "Kolam", "Mandala", "Graffiti"],
        answer: "Kolam"
    }
];

let currentQuestion = 0;
let score = 0;

function loadQuestion() {
    let q = quiz[currentQuestion];
    document.getElementById("question").innerText = q.question;
    let optionsHTML = "";
    q.options.forEach(option => {
        optionsHTML += `<div class="option" onclick="selectAnswer('${option}')">${option}</div>`;
    });
    document.getElementById("options").innerHTML = optionsHTML;
}

function selectAnswer(selected) {
    let correct = quiz[currentQuestion].answer;
    if (selected === correct) {
        score++;
    }
    nextQuestion();
}

function nextQuestion() {
    currentQuestion++;
    if (currentQuestion < quiz.length) {
        loadQuestion();
    } else {
        document.querySelector(".quiz-container").innerHTML =
            `<h2>Quiz Completed 🎉</h2>
             <p>Your Score: ${score} / ${quiz.length}</p>`;
    }
}

loadQuestion();
</script>

</body>
</html>